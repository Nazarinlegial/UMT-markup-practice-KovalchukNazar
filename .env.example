# Base path of the Flora backend API. In dev Vite proxies "/api" to it
# (see vite.config.js), so a relative path is enough — no CORS.
VITE_API_BASE_URL="/api"
# For GitHub Pages / static hosting (lessons 29-30): emit dist/api/*.json and
# fetch the catalogue from those files. Set in CI. For local dev, leave it off.
# VITE_API_MODE=static
